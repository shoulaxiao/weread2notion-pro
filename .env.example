# Notion 配置
# Notion API Token，在 https://www.notion.so/my-integrations 创建
NOTION_TOKEN=your_notion_token_here

# Notion 页面 ID 或 URL，用于同步数据的页面
NOTION_PAGE=your_notion_page_id_or_url_here

# 微信读书配置
# 微信读书的 Cookie，按照文档获取
WEREAD_COOKIE=your_weread_cookie_here

# Cookie Cloud 配置（可选，用于自动获取 Cookie）
# Cookie Cloud 服务地址
CC_URL=https://cookiecloud.malinkang.com/
# Cookie Cloud ID
CC_ID=your_cookie_cloud_id_here
# Cookie Cloud 密码
CC_PASSWORD=your_cookie_cloud_password_here

# 数据库名称配置（可选，默认使用 Notion 中的数据库名称）
BOOK_DATABASE_NAME=书籍
AUTHOR_DATABASE_NAME=作者
CATEGORY_DATABASE_NAME=分类
BOOKMARK_DATABASE_NAME=划线
REVIEW_DATABASE_NAME=笔记
CHAPTER_DATABASE_NAME=章节
YEAR_DATABASE_NAME=年
WEEK_DATABASE_NAME=周
MONTH_DATABASE_NAME=月
DAY_DATABASE_NAME=日
